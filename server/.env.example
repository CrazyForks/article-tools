# Copy this file to `.env` and fill in your values, then run `npm start`.
# .env is git-ignored — never commit your real credentials.

# ── Required ──────────────────────────────────────────────────────────────────
# From 公众号后台 → 设置与开发 → 基本配置 → 开发者ID(AppID) / 开发者密码(AppSecret)
WECHAT_APPID=
WECHAT_APPSECRET=

# ── Cover thumb (draft/add requires one) ──────────────────────────────────────
# Pick ONE of the two. If neither is set, the server falls back to the first
# image in the article body; if the body has no image either, it errors.
#
# (a) A pre-uploaded permanent-material media_id:
WECHAT_THUMB_MEDIA_ID=
# (b) A local image file; the server uploads it once and caches the media_id.
#     Path is relative to this server/ folder, or absolute.
WECHAT_DEFAULT_COVER=

# ── Optional ──────────────────────────────────────────────────────────────────
# Default author shown on the draft (max 8 chars). Can be overridden per-request.
WECHAT_AUTHOR=烁皓
# Port the local service listens on.
PORT=3007
